---
interface Props {
  lang: 'ja' | 'en';
  singlePage?: boolean;
}

const { lang, singlePage = false } = Astro.props;
const endpoint = (import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT ?? '').trim();
const isConfigured = endpoint.length > 0;
const formId = singlePage ? 'contact-form' : `contact-form-${lang}`;

const labels = {
  ja: {
    name: 'お名前',
    namePlaceholder: '山田太郎',
    email: 'メールアドレス',
    message: 'メッセージ',
    messagePlaceholder: 'お問い合わせ内容をご記入ください',
    submit: '送信する',
    unavailable: 'フォーム送信先が未設定です。',
  },
  en: {
    name: 'Name',
    namePlaceholder: 'John Doe',
    email: 'Email',
    message: 'Message',
    messagePlaceholder: 'How can I help?',
    submit: 'Send',
    unavailable: 'The contact form endpoint is not configured.',
  },
};

const subject = singlePage
  ? 'Portfolio contact form'
  : lang === 'ja'
    ? 'ポートフォリオサイトからのお問い合わせ'
    : 'Contact from portfolio site';
---

<form
  class="space-y-6"
  action={isConfigured ? endpoint : undefined}
  method="POST"
  accept-charset="UTF-8"
>
  <input type="hidden" name="subject" value={subject} />
  <input type="hidden" name="_subject" value={subject} />
  <input type="hidden" name="source" value="portfolio" />
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

  <div>
    <label for={`${formId}-name`} class="block mb-2 font-medium">
      {singlePage ? (
        <>
          <span data-lang-content="ja">{labels.ja.name}</span>
          <span data-lang-content="en">{labels.en.name}</span>
        </>
      ) : labels[lang].name}
    </label>
    <input
      type="text"
      id={`${formId}-name`}
      name="name"
      required
      placeholder={labels[lang].namePlaceholder}
      data-placeholder-ja={singlePage ? labels.ja.namePlaceholder : undefined}
      data-placeholder-en={singlePage ? labels.en.namePlaceholder : undefined}
      disabled={!isConfigured}
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-500"
    />
  </div>

  <div>
    <label for={`${formId}-email`} class="block mb-2 font-medium">
      {singlePage ? (
        <>
          <span data-lang-content="ja">{labels.ja.email}</span>
          <span data-lang-content="en">{labels.en.email}</span>
        </>
      ) : labels[lang].email}
    </label>
    <input
      type="email"
      id={`${formId}-email`}
      name="email"
      required
      placeholder="your.email@example.com"
      data-placeholder-ja={singlePage ? 'your.email@example.com' : undefined}
      data-placeholder-en={singlePage ? 'your.email@example.com' : undefined}
      disabled={!isConfigured}
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-500"
    />
  </div>

  <div>
    <label for={`${formId}-message`} class="block mb-2 font-medium">
      {singlePage ? (
        <>
          <span data-lang-content="ja">{labels.ja.message}</span>
          <span data-lang-content="en">{labels.en.message}</span>
        </>
      ) : labels[lang].message}
    </label>
    <textarea
      id={`${formId}-message`}
      name="message"
      rows="5"
      required
      placeholder={labels[lang].messagePlaceholder}
      data-placeholder-ja={singlePage ? labels.ja.messagePlaceholder : undefined}
      data-placeholder-en={singlePage ? labels.en.messagePlaceholder : undefined}
      disabled={!isConfigured}
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-500"
    ></textarea>
  </div>

  <button
    type="submit"
    disabled={!isConfigured}
    class="w-full px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium disabled:cursor-not-allowed disabled:bg-gray-400"
  >
    {singlePage ? (
      <>
        <span data-lang-content="ja">{labels.ja.submit}</span>
        <span data-lang-content="en">{labels.en.submit}</span>
      </>
    ) : labels[lang].submit}
  </button>

  {!isConfigured && (
    <p class="text-sm text-center text-gray-500">
      {singlePage ? (
        <>
          <span data-lang-content="ja">{labels.ja.unavailable}</span>
          <span data-lang-content="en">{labels.en.unavailable}</span>
        </>
      ) : labels[lang].unavailable}
    </p>
  )}
</form>
